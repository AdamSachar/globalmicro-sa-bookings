# Copy this file to ".env" and fill in the values, then load it before starting:
#   set -a; . ./.env; set +a; npm start
# (or use your host's dashboard to set these as environment variables)

# ---- AI (Anthropic / Claude) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides:
# ANTHROPIC_MODEL=claude-sonnet-5
# AI_MAX_TOKENS=400

# ---- WhatsApp Cloud API (Meta) ----
# From your Meta app > WhatsApp > API setup.
WHATSAPP_TOKEN=EAAG...your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# You choose this string; put the SAME value in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=pick-any-secret-string
# App secret (Meta app > Settings > Basic). Used to verify request signatures.
WHATSAPP_APP_SECRET=your-app-secret
# WA_GRAPH_VERSION=v21.0

# ---- Server ----
# PORT=3000
# FAMILY_CONFIG_PATH=./family-config.json
# MEMORY_PATH=./.memory.json
# MEMORY_MAX_TURNS=20
